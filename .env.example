NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

NEXT_PUBLIC_SITE_EMAIL=hello@yourdomain.com

NEXT_PUBLIC_WHATSAPP_PHONE=919876543210

NEXT_PUBLIC_MAP_EMBED_URL=https://www.google.com/maps/embed?pb=PASTE_YOUR_EMBED_SRC

# Resend: https://resend.com/api-keys — put the real key only in .env.local (never commit it)
RESEND_API_KEY=re_your_resend_api_key_here

# Where enquiry notifications land (your inbox)
ENQUIRY_EMAIL_TO=you@yourdomain.com

# Verified sender in Resend. Dev/testing: onboarding@resend.dev — production: yourdomain after DNS verify
RESEND_FROM_EMAIL="HydroProof Leads <onboarding@resend.dev>"
